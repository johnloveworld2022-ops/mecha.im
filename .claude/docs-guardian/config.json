{
  "language": "typescript",
  "framework": "vitepress",
  "docRoot": "website/docs",
  "strictness": "off",
  "stalenessThresholdDays": 30,
  "excludePatterns": [
    "node_modules/**",
    "dist/**",
    "v1/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "packages/spa/src/components/ui/**",
    "packages/integration/**",
    "website/docs/.vitepress/cache/**",
    "website/docs/.vitepress/dist/**"
  ],
  "mappings": [
    { "source": "packages/core/src/**", "docs": ["reference/api/core.md"] },
    { "source": "packages/service/src/**", "docs": ["reference/api/service.md"] },
    { "source": "packages/agent/src/**", "docs": ["reference/api/server.md", "reference/api/runtime.md"] },
    { "source": "packages/process/src/**", "docs": ["reference/api/process.md"] },
    { "source": "packages/connect/src/**", "docs": ["reference/api/connect.md", "features/mesh-networking.md"] },
    { "source": "packages/meter/src/**", "docs": ["reference/api/meter.md", "features/metering.md"] },
    { "source": "packages/mcp-server/src/**", "docs": ["reference/api/mcp-server.md", "features/mcp-server.md"] },
    { "source": "packages/cli/src/**", "docs": ["reference/cli/index.md", "reference/cli/bot.md", "reference/cli/system.md", "reference/cli/node.md", "reference/cli/meter.md", "reference/cli/schedule.md", "reference/cli/plugin.md"] },
    { "source": "packages/spa/src/**", "docs": ["features/dashboard.md", "guide/dashboard.md"] },
    { "source": "packages/sandbox/src/**", "docs": ["features/sandbox.md"] },
    { "source": "packages/server/src/**", "docs": ["reference/api/server.md"] },
    { "source": "packages/runtime/src/**", "docs": ["reference/api/runtime.md"] }
  ]
}
