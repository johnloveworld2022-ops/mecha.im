{
  "language": "typescript",
  "framework": "vitepress",
  "docRoot": "website/docs/",
  "strictness": "warn",
  "stalenessThresholdDays": 30,
  "excludePatterns": [
    "node_modules/**",
    "dist/**",
    "**/fixtures/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "v1/**"
  ],
  "mappings": [
    { "source": "packages/cli/src/commands/*.ts", "doc": "website/docs/reference/cli/index.md" },
    { "source": "packages/agent/src/routes/*.ts", "doc": "website/docs/reference/api/index.md" },
    { "source": "packages/core/src/acl/**/*.ts", "doc": "website/docs/reference/api/core.md" },
    { "source": "packages/sandbox/src/**/*.ts", "doc": "website/docs/reference/api/core.md" },
    { "source": "packages/meter/src/**/*.ts", "doc": "website/docs/reference/api/meter.md" },
    { "source": "packages/connect/src/**/*.ts", "doc": "website/docs/reference/api/connect.md" },
    { "source": "packages/service/src/schedule*.ts", "doc": "website/docs/reference/api/core.md" },
    { "source": "packages/core/src/mecha-settings.ts", "doc": "website/docs/reference/api/core.md" },
    { "source": "packages/core/src/auth-config.ts", "doc": "website/docs/reference/api/core.md" },
    { "source": "packages/core/src/plugin-registry.ts", "doc": "website/docs/reference/api/core.md" },
    { "source": "packages/core/src/constants.ts", "doc": "website/docs/reference/environment.md" },
    { "source": "packages/core/src/discover*.ts", "doc": "website/docs/reference/api/core.md" },
    { "source": "packages/agent/src/auth.ts", "doc": "website/docs/reference/api/index.md" },
    { "source": "packages/process/src/**/*.ts", "doc": "website/docs/reference/api/process.md" },
    { "source": "packages/service/src/**/*.ts", "doc": "website/docs/reference/api/service.md" },
    { "source": "packages/runtime/src/**/*.ts", "doc": "website/docs/reference/api/runtime.md" },
    { "source": "packages/spa/src/**/*.tsx", "doc": "website/docs/reference/components.md" },
    { "source": "packages/mcp-server/src/**/*.ts", "doc": "website/docs/reference/api/mcp-server.md" }
  ]
}
