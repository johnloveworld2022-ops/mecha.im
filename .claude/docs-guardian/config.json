{
  "language": "typescript",
  "framework": "vitepress",
  "docRoot": "website/docs/",
  "strictness": "warn",
  "stalenessThresholdDays": 30,
  "excludePatterns": [
    "node_modules/**",
    "dist/**",
    "**/fixtures/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "v1/**"
  ],
  "mappings": [
    { "source": "packages/cli/src/commands/*.ts", "doc": "website/docs/reference/cli.md" },
    { "source": "packages/agent/src/routes/*.ts", "doc": "website/docs/reference/architecture.md" },
    { "source": "packages/core/src/acl/**/*.ts", "doc": "website/docs/features/permissions.md" },
    { "source": "packages/sandbox/src/**/*.ts", "doc": "website/docs/features/sandbox.md" },
    { "source": "packages/meter/src/**/*.ts", "doc": "website/docs/features/metering.md" },
    { "source": "packages/connect/src/**/*.ts", "doc": "website/docs/features/mesh-networking.md" },
    { "source": "packages/service/src/schedule*.ts", "doc": "website/docs/features/scheduling.md" },
    { "source": "packages/core/src/mecha-settings.ts", "doc": "website/docs/guide/configuration.md" },
    { "source": "packages/core/src/auth-config.ts", "doc": "website/docs/guide/configuration.md" },
    { "source": "packages/core/src/plugin-registry.ts", "doc": "website/docs/guide/configuration.md" },
    { "source": "packages/core/src/constants.ts", "doc": "website/docs/reference/environment.md" },
    { "source": "packages/core/src/discover*.ts", "doc": "website/docs/advanced/multi-machine.md" },
    { "source": "packages/agent/src/auth.ts", "doc": "website/docs/guide/configuration.md" },
    { "source": "packages/process/src/**/*.ts", "doc": "website/docs/reference/architecture.md" },
    { "source": "packages/service/src/**/*.ts", "doc": "website/docs/reference/architecture.md" },
    { "source": "packages/runtime/src/**/*.ts", "doc": "website/docs/reference/architecture.md" },
    { "source": "packages/spa/src/**/*.tsx", "doc": "website/docs/guide/dashboard.md" }
  ]
}
