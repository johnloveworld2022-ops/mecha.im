{
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/deploy-cli.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/docs-sync-check.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "grill@xiaolai": true,
    "loc-guardian@xiaolai": true,
    "tdd-guardian@xiaolai": true,
    "codex-toolkit@xiaolai": true,
    "echo-sleuth@xiaolai": true,
    "docs-guardian@xiaolai": true
  }
}
