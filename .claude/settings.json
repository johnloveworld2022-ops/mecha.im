{
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/tdd-guardian/pretool_guard.py"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/tdd-guardian/taskcompleted_gate.py",
            "timeout": 1800
          }
        ]
      }
    ]
  }
}
