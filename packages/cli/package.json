{
  "name": "@mecha/cli",
  "version": "0.2.0",
  "description": "CLI for mecha.im — local-first multi-agent runtime",
  "type": "module",
  "bin": {
    "mecha": "./dist/main.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@mecha/core": "workspace:*",
    "@mecha/agent": "workspace:*",
    "@mecha/sandbox": "workspace:*",
    "@mecha/service": "workspace:*",
    "@mecha/process": "workspace:*",
    "@mecha/runtime": "workspace:*",
    "commander": "^14.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaolai/mecha.im",
    "directory": "packages/cli"
  }
}
