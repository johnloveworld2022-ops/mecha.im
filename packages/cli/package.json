{
  "name": "@mecha/cli",
  "version": "0.2.11",
  "description": "CLI for mecha.im — local-first multi-agent runtime",
  "type": "module",
  "bin": {
    "mecha": "./dist/main.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@mecha/agent": "workspace:*",
    "@mecha/connect": "workspace:*",
    "@mecha/core": "workspace:*",
    "@mecha/mcp-server": "workspace:*",
    "@mecha/meter": "workspace:*",
    "@mecha/process": "workspace:*",
    "@mecha/runtime": "workspace:*",
    "@mecha/sandbox": "workspace:*",
    "@mecha/server": "workspace:*",
    "@mecha/service": "workspace:*",
    "commander": "^14.0.0",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/qrcode": "^1.5.6"
  }
}
