{
  "name": "@mecha/dashboard",
  "version": "0.2.0",
  "private": true,
  "description": "Web dashboard for mecha.im — local-first multi-agent runtime",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/server-entry.js",
      "types": "./dist/server-entry.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.server.json && next build",
    "dev": "next dev --port 3457",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mecha/core": "workspace:*",
    "@mecha/meter": "workspace:*",
    "@mecha/process": "workspace:*",
    "@mecha/service": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "ISC"
}
