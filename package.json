{
  "name": "mecha.im",
  "version": "0.2.0",
  "private": true,
  "description": "Local-first multi-agent runtime",
  "scripts": {
    "build": "tsc -b packages/core packages/contracts packages/process packages/runtime packages/service packages/cli",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf packages/*/dist",
    "docs:dev": "pnpm --filter @mecha/website dev",
    "docs:build": "pnpm --filter @mecha/website build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
