{
  "name": "mecha.im",
  "version": "0.2.0",
  "private": true,
  "description": "Local-first multi-agent runtime",
  "scripts": {
    "build": "tsc -b packages/core packages/sandbox packages/process packages/runtime packages/service packages/agent packages/meter packages/connect packages/mcp-server packages/dashboard/tsconfig.server.json packages/cli packages/server",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "typecheck": "tsc -b",
    "build:bin": "bash scripts/build-binaries.sh",
    "build:bin:all": "bash scripts/build-binaries.sh all",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo dist/bin",
    "lint": "eslint packages/*/src/",
    "docs:dev": "pnpm --filter @mecha/website dev",
    "docs:build": "pnpm --filter @mecha/website build"
  },
  "keywords": ["ai", "agent", "claude", "multi-agent", "runtime", "local-first"],
  "author": "xiaolai",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
