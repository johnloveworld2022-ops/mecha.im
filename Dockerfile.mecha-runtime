# ---- Build Stage ----
FROM node:20-slim@sha256:c6585df72c34172bebd8d36abed961e231d7d3b5cee2e01294c4495e8a03f687 AS build

# Install build tools for native addons (better-sqlite3)
RUN apt-get update && apt-get install -y --no-install-recommends python3 make g++ && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

WORKDIR /build

# Copy workspace config first for layer caching
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./

# Copy only the packages needed for runtime build
COPY packages/core/package.json packages/core/tsconfig.json ./packages/core/
COPY packages/contracts/package.json packages/contracts/tsconfig.json ./packages/contracts/
COPY packages/runtime/package.json packages/runtime/tsconfig.json ./packages/runtime/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY packages/core/src ./packages/core/src
COPY packages/contracts/src ./packages/contracts/src
COPY packages/runtime/src ./packages/runtime/src

# Build dependencies first, then runtime
RUN pnpm --filter @mecha/core build && pnpm --filter @mecha/contracts build && pnpm --filter @mecha/runtime build

# Prune dev dependencies for production
RUN pnpm --filter @mecha/runtime --prod deploy --legacy /app

# Rebuild native addons (better-sqlite3) in the deployed output
RUN cd /app && npm rebuild better-sqlite3

# ---- Production Stage ----
FROM node:20-slim@sha256:c6585df72c34172bebd8d36abed961e231d7d3b5cee2e01294c4495e8a03f687 AS production

# Install tini and Tailscale CLI for mesh networking
RUN apt-get update && apt-get install -y --no-install-recommends \
    tini=0.19.0-1+b3 \
    curl ca-certificates \
    && curl -fsSL https://pkgs.tailscale.com/stable/debian/bookworm.noarmor.gpg \
       -o /usr/share/keyrings/tailscale-archive-keyring.gpg \
    && curl -fsSL https://pkgs.tailscale.com/stable/debian/bookworm.tailscale-keyring.list \
       -o /etc/apt/sources.list.d/tailscale.list \
    && apt-get update && apt-get install -y --no-install-recommends tailscale \
    && apt-get purge -y curl \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

# Rename the existing node user/group (uid=1000, gid=1000) to mecha
RUN groupmod -n mecha node && \
    usermod -l mecha -d /home/mecha -m node

# Install Claude Code, Codex, and Gemini CLIs globally
RUN npm install -g @anthropic-ai/claude-code @openai/codex @google/gemini-cli

# Create required writable directories and Claude onboarding flag
RUN mkdir -p /var/lib/mecha /tmp /home/mecha/.claude && \
    echo '{"hasCompletedOnboarding": true}' > /home/mecha/.claude.json && \
    chown -R mecha:mecha /var/lib/mecha /home/mecha

WORKDIR /app

# Copy built application from build stage
COPY --from=build --chown=mecha:mecha /app /app

# Switch to non-root user
USER mecha

# Expose the runtime HTTP port
EXPOSE 3000

# Use tini as init process for proper signal handling
ENTRYPOINT ["tini", "--"]

# Start the runtime server
CMD ["node", "dist/main.js"]
